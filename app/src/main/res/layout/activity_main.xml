<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pink_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/pink_primary"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/txtWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome, Ms. Triza 💖"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"
                android:textColor="@color/pink_secondary_variant"/>

            <Button
                android:id="@+id/btnNotif"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="Materi Notification (P14)"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/pink_primary"
                app:icon="@android:drawable/ic_dialog_info" />

            <Button
                android:id="@+id/btnRumus"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="Kalkulator Rumus"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/pink_secondary"
                app:icon="@android:drawable/ic_menu_edit" />

            <Button
                android:id="@+id/btnProfile"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="User Profile"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/pink_primary"
                app:icon="@android:drawable/ic_menu_myplaces" />

            <Button
                android:id="@+id/btnDashboardFood"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="Dashboard Food"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/pink_secondary"
                app:icon="@android:drawable/ic_menu_gallery" />

            <Button
                android:id="@+id/btnWebView"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="Bina Desa Website"
                android:layout_marginBottom="40dp"
                android:backgroundTint="@color/pink_primary"
                app:icon="@android:drawable/ic_menu_search" />

            <Button
                android:id="@+id/btnLogout"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout Account"
                android:textColor="@color/pink_secondary_variant"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>