<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F8BBD0"
    android:padding="24dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Tutorial Detail Icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Klik untuk Melihat Detail! 💖"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#AD1457"
        android:gravity="center"
        android:layout_marginTop="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih salah satu pesan untuk melihat detail lengkap. Kamu juga bisa melakukan aksi seperti membalas, menyimpan, atau membagikan pesan tersebut."
        android:textSize="16sp"
        android:textColor="#D81B60"
        android:gravity="center"
        android:layout_marginTop="16dp" />
</LinearLayout>